{
  "cli": {
    "appVersionSource": "local",
    "version": ">= 16.4.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "distribution": "internal"
      },
      "ios": {
        "simulator": true
      }
    },
    "ios-internal": {
      "distribution": "internal",
      "ios": {
        "distribution": "internal"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {}
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    }
  },
  "submit": {
    "production": {
      "ios": {},
      "android": {}
    }
  }
}
